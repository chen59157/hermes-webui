# ============================================================
# Hermes WebUI — 环境变量配置模板
# ============================================================
# 复制此文件为 .hermes/.env 并填入你的真实 API Key
# 切勿将包含真实 Key 的 .env 文件提交到版本控制
# ============================================================

# ── 核心 API 提供商 ─────────────────────────────────────────

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (GPT / o-series)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter (多模型聚合)
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google / Gemini
# GOOGLE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 中国 / 亚太区 API 提供商 ────────────────────────────────

# DeepSeek
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 智谱 AI (GLM / Z.AI)
# GLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 月之暗面 Kimi
# KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Xiaomi MiMo
# XIAOMI_API_KEY=tp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1

# MiniMax
# MINIMAX_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MINIMAX_CN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 其他 API 提供商 ─────────────────────────────────────────

# Mistral AI
# MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# xAI (Grok)
# XAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenCode (Zen / Go)
# OPENCODE_ZEN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENCODE_GO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 本地 / 自托管 ────────────────────────────────────────────

# Ollama Cloud
# OLLAMA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LM Studio (本地)
# LM_API_KEY=lm-studio
# LM_BASE_URL=http://localhost:1234/v1

# NVIDIA NIM
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx